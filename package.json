{
  "name": "upcheck",
  "version": "1.3.2",
  "description": "Cross-platform desktop app for monitoring service status",
  "author": "Thomas",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "test": "vitest run"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.upcheck.app",
    "productName": "UpCheck",
    "publish": {
      "provider": "github",
      "owner": "thomas-stk",
      "repo": "upcheck"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "identity": "-",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "build/png/icon_1024.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/png/icon_256.png"
    },
    "dmg": {
      "background": "build/background.png",
      "window": {
        "width": 660,
        "height": 400
      },
      "contents": [
        { "x": 180, "y": 190, "type": "file" },
        { "x": 480, "y": 190, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
